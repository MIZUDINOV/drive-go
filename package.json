{
  "name": "drive-go",
  "description": "Drive GO - Chrome extension for managing your Google Drive files",
  "private": true,
  "version": "0.8.0",
  "type": "module",
  "scripts": {
    "dev": "wxt",
    "dev:firefox": "wxt -b firefox",
    "lint": "npx prettier --check entrypoints/",
    "lint:fix": "npx prettier --write entrypoints/",
    "build": "wxt build",
    "build:firefox": "wxt build -b firefox",
    "zip": "wxt zip",
    "zip:firefox": "wxt zip -b firefox",
    "compile": "tsc --noEmit",
    "postinstall": "wxt prepare"
  },
  "dependencies": {
    "@kobalte/core": "^0.13.11",
    "@solid-primitives/i18n": "^2.2.1",
    "idb": "^8.0.3",
    "material-symbols": "^0.40.2",
    "rxjs": "^7.8.2",
    "solid-js": "^1.9.11"
  },
  "devDependencies": {
    "@wxt-dev/module-solid": "^1.1.4",
    "typescript": "^5.9.3",
    "wxt": "^0.20.18"
  }
}
